{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "UE session metrics: registrations, PDU sessions, success/failure rates",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "gnb", "legendFormat": "gNBs", "refId": "A" }],
      "title": "Active gNBs",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] },
          "unit": "short", "min": 0
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "ran_ue", "legendFormat": "RAN UEs", "refId": "A" }],
      "title": "Active RAN UEs",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] },
          "unit": "short", "min": 0
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "amf_ue", "legendFormat": "AMF UEs", "refId": "A" }],
      "title": "Active AMF UEs",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] },
          "unit": "short", "min": 0
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "smf_sessions", "legendFormat": "SMF Sessions", "refId": "A" }],
      "title": "PDU Sessions (SMF)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "short", "min": 0
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "increase(fivegs_amffunction_mm_regtermreq_total[5m]) or vector(0)", "legendFormat": "Failed Regs", "refId": "A" }],
      "title": "Failed Registrations (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 100 }, { "color": "yellow", "value": 95 }, { "color": "red", "value": 90 }] },
          "unit": "percent", "min": 0, "max": 100
        }, "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{
        "expr": "clamp_max(100 * (1 - (increase(fivegs_amffunction_mm_regtermreq_total[5m]) / clamp_min(increase(fivegs_amffunction_mm_conestabsucc_total[5m]), 1))), 100) or vector(100)",
        "legendFormat": "Success %", "refId": "A"
      }],
      "title": "Registration Success Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short", "min": 0
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "gnb", "legendFormat": "gNBs", "refId": "A" },
        { "expr": "ran_ue", "legendFormat": "RAN UEs", "refId": "B" },
        { "expr": "amf_ue", "legendFormat": "AMF UEs", "refId": "C" },
        { "expr": "smf_sessions", "legendFormat": "PDU Sessions", "refId": "D" }
      ],
      "title": "UE & Session Counts Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps", "min": 0
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(fivegs_amffunction_mm_conestabsucc_total[1m])", "legendFormat": "Connection Establishments/s", "refId": "A" },
        { "expr": "rate(fivegs_amffunction_mm_regtermreq_total[1m])", "legendFormat": "Registration Terminations/s", "refId": "B" },
        { "expr": "rate(fivegs_pcffunction_pa_policyamassoreq_total[1m])", "legendFormat": "PCF AM Policy Req/s", "refId": "C" }
      ],
      "title": "Registration & Session Rates",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short", "min": 0
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "fivegs_ep_n3_gtp_indatapktn3upf", "legendFormat": "UPF N3 IN pkts", "refId": "A" },
        { "expr": "fivegs_ep_n3_gtp_outdatapktn3upf", "legendFormat": "UPF N3 OUT pkts", "refId": "B" }
      ],
      "title": "UPF GTP Packet Counts (Cumulative)",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["open5gs", "5g", "ue", "sessions"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Open5GS — UE Sessions",
  "uid": "open5gs-ue-sessions",
  "version": 1
}
