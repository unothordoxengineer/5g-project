      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"open5gs\",pod=~\"upf-.*\",container=\"upf\"}[1m]))*100", "legendFormat": "UPF", "refId": "A" }],
